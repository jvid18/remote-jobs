# Public vars — inlined at build time, visible in bundle
# Prefix with EXPO_PUBLIC_ to expose to client code

# Remotive API base URL (defaults to https://remotive.com/api when unset)
EXPO_PUBLIC_REMOTIVE_API_URL=https://remotive.com/api

# Filter jobs in the client (true, default) instead of via API params.
# Kept as an escape hatch: flip to false once the Remotive filter params work.
EXPO_PUBLIC_CLIENT_SIDE_FILTERS=true
